VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Kimi (Moonshot) API key for Movement Analysis AI insights
KIMI_API_KEY=your_kimi_api_key

# Production hosting (Railway / custom domain)
# Leave SITE_BASE_PATH empty for ascendia-climb.com
# SITE_BASE_PATH=
# PUBLIC_SITE_URL=https://ascendia-climb.com
# MEDIAPIPE_APP_URL=https://ascendia-climb.com/mediapipe-samples-web/
# KIMI_API_KEY=...               (required for AI analysis on Railway)

# GitHub Pages project site only (not needed for custom domains)
# SITE_BASE_PATH=/ascendia

# Optional override for post-login redirect (defaults to /mediapipe-samples-web/)
# MEDIAPIPE_APP_URL=http://localhost:5174/mediapipe-samples-web/
